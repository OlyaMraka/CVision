@*
    Views/Hub/Components/_UploadCard.cshtml
    ════════════════════════════════════════
    Компонент: картка завантаження файлу CV.
    Містить: drag-and-drop зону, input, прев'ю файлу, кнопки.

    Використовується: Views/Home/Hub.cshtml
    JS-логіка: wwwroot/js/hub-analysis.js
*@

<div class="hub-upload" id="dropZone">

    <input type="file"
           id="cvFileInput"
           accept=".pdf,.docx,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
           style="display:none;" />

    {{! Плейсхолдер — до вибору файлу }}
    <div id="uploadPlaceholder">
        <div class="hub-upload__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
        </div>
        <div class="hub-upload__title">Завантажте ваше резюме</div>
        <p class="hub-upload__hint">
            Підтримувані формати: PDF, DOCX.<br />
            Максимальний розмір файлу 10MB.
        </p>
    </div>

    {{! Прев'ю після вибору файлу (керується JS) }}
    <div id="filePreviewWrap" style="display:none; width:100%; text-align:center;">

        <img id="filePreviewImg" class="hub-upload__preview"
             src="" alt="Прев'ю CV" style="display:none;" />

        {{! Іконка-заглушка для PDF/DOCX }}
        <div id="filePreviewIcon" style="display:none; margin:0 auto .75rem;">
            <div style="width:80px;height:100px;background:#fde8ef;
                        border-radius:10px;display:flex;flex-direction:column;
                        align-items:center;justify-content:center;
                        margin:0 auto;box-shadow:0 4px 16px rgba(0,0,0,.1);">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                     stroke="#e8547a" stroke-width="1.8"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                </svg>
                <span id="fileExtBadge"
                      style="font-size:.6rem;font-weight:800;
                             color:#e8547a;margin-top:4px;letter-spacing:.05em;">PDF</span>
            </div>
        </div>

        <div class="hub-upload__filename" id="fileNameLabel" style="display:inline-block;"></div>
    </div>

    {{! Кнопки }}
    <div class="hub-upload__actions">
        <button class="btn-pick"    type="button" id="pickFileBtn">Обрати файл</button>
        <button class="btn-analyze" type="button" id="analyzeBtn" disabled>Аналізувати зараз</button>
    </div>

</div>
