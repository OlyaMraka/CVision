@*
    Views/Account/Register.cshtml
    ════════════════════════════════════════════════════════════════
    Модалка Реєстрації.
    Зміни:
      - @model виправлено на повний namespace AuthViewModels
      - Додано поле PhoneNumber (номер телефону)
      - Прибрано чекбокс конфіденційності, Google/LinkedIn
    ════════════════════════════════════════════════════════════════
*@

@model CVision.Models.ViewModels.AuthViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Реєстрація";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/LadingPage.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css"       asp-append-version="true" />
}


<div class="hero" style="display:flex;align-items:center;justify-content:center;">

    <div class="modal-overlay is-open" id="registerOverlay">
        <div class="modal" role="dialog" aria-modal="true" aria-labelledby="registerTitle">

            <!-- ── Кнопка × ───────────────────────────────── -->
            <button class="modal__close"
                    type="button"
                    onclick="window.location.href='/'"
                    aria-label="Закрити">
                &#x2715;
            </button>

            <!-- ── Заголовок ──────────────────────────────── -->
            <h1 class="modal__title" id="registerTitle">Реєстрація</h1>
            <p class="modal__subtitle">Створіть своє професійне резюме безкоштовно</p>

            @*
                Форма POST → AccountController.Register(RegisterViewModel)
                Контролер маппить ViewModel → RegisterUserRequestDto
                і відправляє в BLL через Mediator (RegisterUserCommand)
            *@
            <form asp-controller="Account"
                  asp-action="Register"
                  method="post"
                  novalidate>

                @Html.AntiForgeryToken()

                <!-- ── Поле: Повне ім'я ───────────────────── -->
                <div class="form-group">
                    <label class="form-group__label" asp-for="FullName">Повне ім'я</label>
                    <div class="form-group__input-wrap">
                        <span class="form-group__icon-left" aria-hidden="true">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                        </span>
                        <input asp-for="FullName"
                               class="form-group__input form-group__input--no-right"
                               type="text"
                               placeholder="Олександр Петренко"
                               autocomplete="name" />
                    </div>
                    <span asp-validation-for="FullName" class="form-group__error"></span>
                </div>

                <!-- ── Поле: Електронна пошта ─────────────── -->
                <div class="form-group">
                    <label class="form-group__label" asp-for="Email">Електронна пошта</label>
                    <div class="form-group__input-wrap">
                        <span class="form-group__icon-left" aria-hidden="true">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="4" width="20" height="16" rx="2"/>
                                <path d="m2 7 10 7 10-7"/>
                            </svg>
                        </span>
                        <input asp-for="Email"
                               class="form-group__input form-group__input--no-right"
                               type="email"
                               placeholder="name@example.com"
                               autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="form-group__error"></span>
                </div>

                <!-- ── Поле: Номер телефону ───────────────── -->
                @*
                    type="tel" — мобільні браузери показують цифрову клавіатуру.
                    Валідація формату (+380...) — через Phone атрибут у ViewModel.
                *@
                <div class="form-group">
                    <label class="form-group__label" asp-for="PhoneNumber">Номер телефону</label>
                    <div class="form-group__input-wrap">
                        <span class="form-group__icon-left" aria-hidden="true">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2
                                         19.79 19.79 0 0 1-8.63-3.07
                                         19.5  19.5  0 0 1-6-6
                                         19.79 19.79 0 0 1-3.07-8.67
                                         A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72
                                         c.127.96.361 1.903.7 2.81
                                         a2 2 0 0 1-.45 2.11L8.09 9.91
                                         a16 16 0 0 0 6 6l1.27-1.27
                                         a2 2 0 0 1 2.11-.45
                                         c.907.339 1.85.573 2.81.7
                                         A2 2 0 0 1 22 16.92z"/>
                            </svg>
                        </span>
                        <input asp-for="PhoneNumber"
                               class="form-group__input form-group__input--no-right"
                               type="tel"
                               placeholder="+380 XX XXX XX XX"
                               autocomplete="tel" />
                    </div>
                    <span asp-validation-for="PhoneNumber" class="form-group__error"></span>
                </div>

                <!-- ── Поле: Пароль ───────────────────────── -->
                <div class="form-group">
                    <label class="form-group__label" asp-for="Password">Пароль</label>
                    <div class="form-group__input-wrap">
                        <span class="form-group__icon-left" aria-hidden="true">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                        </span>
                        <input asp-for="Password"
                               id="registerPassword"
                               class="form-group__input"
                               type="password"
                               placeholder="Мінімум 8 символів"
                               autocomplete="new-password" />
                        <button class="form-group__toggle-pass"
                                type="button"
                                onclick="togglePassword('registerPassword', this)"
                                aria-label="Показати пароль">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8
                                         a18.45 18.45 0 0 1 5.06-5.94"/>
                                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8
                                         a18.5 18.5 0 0 1-2.16 3.19"/>
                                <line x1="1" y1="1" x2="23" y2="23"/>
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="form-group__error"></span>
                </div>

                <!-- ── Кнопка Submit ──────────────────────── -->
                <button class="btn-auth" type="submit">Зареєструватися</button>

                @*
                    ModelOnly — показує тільки помилки без прив'язки до поля,
                    які контролер додає через:
                    ModelState.AddModelError(string.Empty, "повідомлення")
                    Наприклад: "Email вже зайнятий", "Сервіс тимчасово недоступний"
                *@
                <span asp-validation-summary="ModelOnly"
                      class="form-group__error"
                      style="display:block;text-align:center;margin-top:.6rem;"></span>

            </form>

            <!-- ── Підвал ─────────────────────────────────── -->
            <p class="modal__footer-text" style="margin-top:1.2rem;">
                Вже маєте акаунт?
                <a asp-controller="Account" asp-action="Login">Увійти</a>
            </p>

        </div>
    </div>

</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            const isHidden = input.type === 'password';
            input.type = isHidden ? 'text' : 'password';
            btn.innerHTML = isHidden
                ? `<svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                     <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                     <circle cx="12" cy="12" r="3"/>
                   </svg>`
                : `<svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                     <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8
                              a18.45 18.45 0 0 1 5.06-5.94"/>
                     <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8
                              a18.5 18.5 0 0 1-2.16 3.19"/>
                     <line x1="1" y1="1" x2="23" y2="23"/>
                   </svg>`;
        }

        document.getElementById('registerOverlay').addEventListener('click', function (e) {
            if (e.target === this) { window.location.href = '/'; }
        });
    </script>
}
